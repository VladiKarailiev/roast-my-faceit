# ── Required ────────────────────────────────────────────────────────
# Get a server-side key at https://developers.faceit.com
# DO NOT prefix with NEXT_PUBLIC_ — it must stay on the server.
FACEIT_API_KEY=

# ── Recommended ─────────────────────────────────────────────────────
# Your public site URL. Used for canonical, OG, sitemap, robots.
# In Vercel: set this to your deployed URL (e.g. https://roastmyfaceit.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: search engine verification ────────────────────────────
# Each adds a single <meta> tag if set. Leave blank to omit.
# Google Search Console → Settings → Ownership verification → HTML tag.
# Paste only the value of the `content="..."` attribute.
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools (msvalidate.01)
BING_VERIFICATION=
# Yandex Webmaster
YANDEX_VERIFICATION=
